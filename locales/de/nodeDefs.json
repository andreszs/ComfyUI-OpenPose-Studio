{
  "OpenPoseStudio": {
    "display_name": "OpenPose Studio",
    "description": "Rendert ein Pose-JSON als Bild und gibt zusätzlich das gefilterte JSON und den POSE_KEYPOINT-Ausgang aus.",
    "inputs": {
      "pose_json": {
        "name": "Pose JSON",
        "tooltip": "Pose-JSON-Daten (unterstützt Legacy- und Standardformate)."
